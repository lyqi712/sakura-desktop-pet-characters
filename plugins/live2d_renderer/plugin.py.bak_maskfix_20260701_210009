            18000,
        ),
        "layers": _normalize_scene_action_layers(value.get("layers")),
        "transients": _normalize_scene_action_mapping(value.get("transients")),
        "motions": _normalize_scene_motion_mapping(value.get("motions")),
        "events": _normalize_scene_event_mapping(value.get("events")),
        "idlePool": _normalize_scene_action_list(value.get("idle_pool", value.get("idlePool"))),
    }
    return normalized


def _normalize_scene_action_layers(value: Any) -> dict[str, list[dict[str, Any]]]:
    if not isinstance(value, dict):
        return {}
    result: dict[str, list[dict[str, Any]]] = {}
    for raw_layer, raw_items in value.items():
        layer = str(raw_layer or "").strip()
        if not layer:
            continue
        items = raw_items if isinstance(raw_items, (list, tuple)) else [raw_items]
        normalized_items = [
            action
            for action in (_normalize_param_action(item) for item in items)
            if action is not None
        ]
        if normalized_items:
            result[layer] = normalized_items
    return result


def _normalize_scene_action_mapping(value: Any) -> dict[str, dict[str, Any]]:
    if not isinstance(value, dict):
        return {}
    result: dict[str, dict[str, Any]] = {}
    for raw_id, raw_action in value.items():
        action_id = str(raw_id or "").strip()
        if not action_id:
            continue
        action_source = dict(raw_action) if isinstance(raw_action, dict) else raw_action
        if isinstance(action_source, dict):
            action_source.setdefault("id", action_id)
        action = _normalize_param_action(action_source)
        if action is not None:
            action["id"] = action_id
            result[action_id] = action
    return result


def _normalize_scene_motion_mapping(value: Any) -> dict[str, dict[str, Any]]:
    if not isinstance(value, dict):
        return {}
    result: dict[str, dict[str, Any]] = {}
    for raw_id, raw_motion in value.items():
        motion_id = str(raw_id or "").strip()
        if not motion_id or not isinstance(raw_motion, dict):
            continue
        motion = str(raw_motion.get("motion") or raw_motion.get("name") or "").strip()
        if not motion:
            continue
        result[motion_id] = {
            "id": motion_id,
            "motion": motion,
            "loop": bool(raw_motion.get("loop", False)),
        }
    return result


def _normalize_scene_event_mapping(value: Any) -> dict[str, list[dict[str, Any]]]:
    if not isinstance(value, dict):
        return {}
    result: dict[str, list[dict[str, Any]]] = {}
    for raw_event, raw_actions in value.items():
        event_name = str(raw_event or "").strip()
        if not event_name:
            continue
        actions = _normalize_scene_action_list(raw_actions)
        if actions:
            result[event_name] = actions
    return result


def _normalize_scene_action_list(value: Any) -> list[dict[str, Any]]:
    if isinstance(value, dict):
        items = [value]
    elif isinstance(value, (list, tuple)):
        items = list(value)
    else:
        return []
    actions: list[dict[str, Any]] = []
    for item in items:
        if not isinstance(item, dict):
            continue
        kind = str(item.get("kind") or "").strip()
        if not kind:
            continue
        action: dict[str, Any] = {"kind": kind}
        for key in (
            "id",
            "layer",
            "name",
            "params",
            "reset_params",
            "resetParams",
            "duration_ms",
            "durationMs",
            "weight",
        ):
            if key in item:
                action[_camel_scene_key(key)] = item[key]
        if "params" in action:
            action["params"] = _normalize_safe_reset_params(action["params"])
        if "resetParams" in action:
            action["resetParams"] = _normalize_safe_reset_params(action["resetParams"])
        if "durationMs" in action:
            action["durationMs"] = _normalize_positive_int(action["durationMs"], 0)
        if "weight" in action:
            action["weight"] = _normalize_weight(action["weight"])
        actions.append(action)
    return actions


def _normalize_param_action(value: Any) -> dict[str, Any] | None:
    if not isinstance(value, dict):
        return None
    action_id = str(value.get("id") or value.get("name") or "").strip()
    params = _normalize_safe_reset_params(value.get("params"))
    if not action_id or not params:
        return None
    action: dict[str, Any] = {
        "id": action_id,
        "params": params,
    }
    reset_params = _normalize_safe_reset_params(
        value.get("reset_params", value.get("resetParams"))
    )
    if reset_params:
        action["resetParams"] = reset_params
    duration_ms = _normalize_positive_int(
        value.get("duration_ms", value.get("durationMs")),
        0,
    )
    if duration_ms:
        action["durationMs"] = duration_ms
    return action


def _camel_scene_key(key: str) -> str:
    if key == "reset_params":
        return "resetParams"
    if key == "duration_ms":
        return "durationMs"
    return key


def _normalize_positive_int(value: Any, default: int) -> int:
    try:
        parsed = int(str(value).strip())
    except (TypeError, ValueError):
        return default
    return parsed if parsed > 0 else default


def _normalize_weight(value: Any) -> float:
    try:
        parsed = float(value)
    except (TypeError, ValueError):
        return 1.0
    return parsed if parsed > 0 else 1.0


def _normalize_string_list(value: Any) -> list[str]:
    if isinstance(value, str):
        candidates = [value]
    elif isinstance(value, (list, tuple, set)):
        candidates = list(value)
    else:
        return []

    result: list[str] = []
    for item in candidates:
        text = str(item or "").strip()
        if text and text not in result:
            result.append(text)
    return result


def _wait_for_live2d_status(view: Any, *, timeout_ms: int) -> dict[str, Any]:
    loop = QEventLoop()
    result: dict[str, Any] = {"done": False, "timeout": False}
    deadline = QTimer()
    deadline.setSingleShot(True)

    def finish(value: dict[str, Any]) -> None:
        nonlocal result
        if loop.isRunning():
            result = value
            loop.quit()

    def poll() -> None:
        js = "JSON.stringify(window.__sakuraLive2DStatus || {missing:true})"

        def got(value: Any) -> None:
            try:
                data = json.loads(value) if isinstance(value, str) and value else {"raw": value}
            except Exception as exc:  # noqa: BLE001
                data = {"parse_error": str(exc), "raw": value}
            if data.get("done") or data.get("errors"):
                finish(data)
            else:
                QTimer.singleShot(250, poll)

        view.page().runJavaScript(js, got)

    deadline.timeout.connect(lambda: finish({"done": False, "timeout": True}))
    QTimer.singleShot(500, poll)
    deadline.start(timeout_ms)
    loop.exec()
    return result


class Live2DRendererPlugin(PluginBase):
    plugin_id = "live2d_renderer"
    plugin_version = "1.0.0"

    def initialize(self, register: PluginCapabilityRegistry, context: PluginContext) -> None:
        register.register_renderer(
            RendererContribution(
                renderer_type="live2d",
                display_name="Live2D",
                create=lambda ctx: Live2DRenderer(ctx),
                plugin_id=self.plugin_id,
                priority=50,
            )
        )

