def _normalize_mode(value: Any) -> str:
    mode = str(value or "half").strip().lower()
    return mode if mode in {"full", "half"} else "half"


def _geometry_close(
    previous: tuple[int, int, int, int, int] | None,
    current: tuple[int, int, int, int, int],
) -> bool:
    if previous is None:
        return False
    return all(
        abs(int(left) - int(right)) <= _GEOMETRY_JITTER_PX
        for left, right in zip(previous, current)
    )


def _normalize_model_scale(value: Any) -> float:
    """Normalize user model scale."""
    try:
        scale = float(value)
    except (TypeError, ValueError):
        return 1.0
    if scale <= 0:
        return 1.0
    return max(0.3, min(3.0, scale))


def _normalize_layout_scale(value: Any, default: float) -> float:
    """Normalize per-mode layout scale."""
    try:
        scale = float(value)
    except (TypeError, ValueError):
        return default
    if scale <= 0:
        return default
    return max(0.2, min(4.0, scale))


def _normalize_resolution_scale(value: Any) -> float:
    """Normalize additional DPR scaling."""
    try:
        scale = float(value)
    except (TypeError, ValueError):
        return 1.8
    if scale <= 0:
        return 1.8
    return max(1.0, min(3.0, scale))


def _normalize_max_resolution(value: Any) -> float:
    """Clamp WebGL canvas resolution."""
    try:
        scale = float(value)
    except (TypeError, ValueError):
        return 4.5
    if scale <= 0:
        return 4.5
    return max(1.0, min(5.0, scale))


def _normalize_offset_ratio(value: Any, default: float) -> float:
    """Normalize model Y offset as a layout-height ratio."""
    try:
        offset = float(value)
    except (TypeError, ValueError):
        return default
    return max(-1.0, min(1.0, offset))


def _normalize_safe_reset_params(value: Any) -> dict[str, float]:
    if not isinstance(value, dict):
        return {}
    normalized: dict[str, float] = {}
    for key, raw in value.items():
        name = str(key or "").strip()
        if not name:
            continue
        try:
            normalized[name] = float(raw)
        except (TypeError, ValueError):
            continue
    return normalized


