_SCENE_ACTIONS_SCRIPT = """
// Configurable scene actions: persistent layers, transient params, motions, and event hooks.
function _sceneActionObject(value) {
  return value && typeof value === 'object' && !Array.isArray(value) ? value : {};
}
function _sceneActionArray(value) {
  if (Array.isArray(value)) return value;
  if (value && typeof value === 'object') return [value];
  return [];
}
function _sceneActionParams(value) {
  return _sceneActionObject(value);
}
function _sceneActionParamNames(action) {
  var params = _sceneActionParams(action && action.params);
  return Object.keys(params);
}
function _sceneActionFind(items, id) {
  var wanted = String(id || '');
  for (var i = 0; i < items.length; i++) {
    if (String(items[i].id || '') === wanted) return items[i];
  }
  return null;
}
window.SakuraLive2DSceneActions = {
  activeLayers: {},
  transientTimers: {},
  idleTimer: null,
  ownParam: function(param, owned) {
    var key = String(param || '').trim();
    if (!key) return;
    if (owned) _SCENE_ACTION_OWNED_PARAMS[key] = true;
    else delete _SCENE_ACTION_OWNED_PARAMS[key];
  },
  writeParams: function(params, owned) {
    var cm = _getCoreModel();
    if (!cm || typeof cm.setParameterValueByIndex !== 'function') return;
    var ids = _parameterIds(cm);
    params = _sceneActionParams(params);
    var names = Object.keys(params);
    for (var i = 0; i < names.length; i++) {
      var param = names[i];
      var value = Number(params[param]);
      if (!isFinite(value)) continue;
      _setParamByName(cm, ids, param, value);
      if (owned) SakuraLive2DSceneActions.ownParam(param, true);
    }
    _applyRenderGuards(cm, true);
  },
  resetParams: function(params, resetParams) {
    var cm = _getCoreModel();
    if (!cm || typeof cm.setParameterValueByIndex !== 'function') return;
    var ids = _parameterIds(cm);
    params = _sceneActionParams(params);
    resetParams = _sceneActionParams(resetParams);
    var names = Object.keys(params);
    for (var i = 0; i < names.length; i++) {
      var param = names[i];
      var value = Object.prototype.hasOwnProperty.call(resetParams, param) ? Number(resetParams[param]) : 0;
      if (!isFinite(value)) value = 0;
      _setParamByName(cm, ids, param, value);
      SakuraLive2DSceneActions.ownParam(param, false);
    }
    _applyRenderGuards(cm, true);
  },
  clearLayer: function(layerName) {
    var layers = _sceneActionObject(_SCENE_ACTIONS.layers);
    var items = _sceneActionArray(layers[layerName]);
    for (var i = 0; i < items.length; i++) {
      this.resetParams(items[i].params, items[i].resetParams);
    }
    delete this.activeLayers[layerName];
  },
  applyLayer: function(layerName, id) {
    var layers = _sceneActionObject(_SCENE_ACTIONS.layers);
    var items = _sceneActionArray(layers[layerName]);
    var action = _sceneActionFind(items, id);
    if (!action) return false;
    this.clearLayer(layerName);
    this.writeParams(action.params, true);
    this.activeLayers[layerName] = action;
    return true;
  },
  applyTransient: function(id, durationMs) {
    var transients = _sceneActionObject(_SCENE_ACTIONS.transients);
    var action = transients[String(id || '')];
    if (!action) return false;
    var duration = Number(durationMs || action.durationMs || 1600);
    if (!isFinite(duration) || duration <= 0) duration = 1600;
    if (this.transientTimers[id]) clearTimeout(this.transientTimers[id]);
    this.writeParams(action.params, true);
    this.transientTimers[id] = setTimeout(function() {
      SakuraLive2DSceneActions.resetParams(action.params, action.resetParams);
      delete SakuraLive2DSceneActions.transientTimers[id];
    }, duration);
    return true;
  },
  playMotionAction: function(id) {
    var motions = _sceneActionObject(_SCENE_ACTIONS.motions);
    var action = motions[String(id || '')];
    if (!action || !action.motion) return false;
    playMotion(action.motion, !!action.loop);
    return true;
  },
  runAction: function(action, payload) {
    action = _sceneActionObject(action);
    var kind = String(action.kind || '').trim();
    try {
      if (kind === 'layer') return this.applyLayer(action.layer, action.id);
      if (kind === 'transient') return this.applyTransient(action.id, action.durationMs);
      if (kind === 'motion') return this.playMotionAction(action.id);
      if (kind === 'expression') {
        setExpression(action.name || action.id || '', Number(action.weight || 1.0));
        return true;
      }
      if (kind === 'params') {
        this.writeParams(action.params, true);
        var duration = Number(action.durationMs || 0);
        if (isFinite(duration) && duration > 0) {
          setTimeout(function() {
            SakuraLive2DSceneActions.resetParams(action.params, action.resetParams);
          }, duration);
        }
        return true;
      }
    } catch (error) {
      _recordExpressionError('scene-action-' + kind, error);
    }
    return false;
  },
  runActions: function(actions, payload) {
    var list = _sceneActionArray(actions);
    for (var i = 0; i < list.length; i++) this.runAction(list[i], payload || {});
  },
  pickWeighted: function(pool) {
    var items = _sceneActionArray(pool);
    if (!items.length) return null;
    var total = 0;
    for (var i = 0; i < items.length; i++) {
      var weight = Number(items[i].weight || 1);
      if (isFinite(weight) && weight > 0) total += weight;
    }
    if (total <= 0) return items[Math.floor(Math.random() * items.length)];
    var cursor = Math.random() * total;
    for (var j = 0; j < items.length; j++) {
      var itemWeight = Number(items[j].weight || 1);
      if (!isFinite(itemWeight) || itemWeight <= 0) continue;
      cursor -= itemWeight;
      if (cursor <= 0) return items[j];
    }
    return items[items.length - 1];
  },
  runIdleAction: function() {
    if (_SCENE_ACTIONS.enabled === false) return;
    var action = this.pickWeighted(_SCENE_ACTIONS.idlePool);
    if (action) this.runAction(action, {source: 'idle'});
  },
  startIdleTimer: function() {
    if (_SCENE_ACTIONS.enabled === false || this.idleTimer) return;
    var interval = Number(_SCENE_ACTIONS.idleIntervalMs || 18000);
    if (!isFinite(interval) || interval < 3000) interval = 18000;
    this.idleTimer = setInterval(function() {
      _runSceneIdleAction();
    }, interval);
  },
  dispatch: function(eventName, payload) {
    if (_SCENE_ACTIONS.enabled === false) return;
    var events = _sceneActionObject(_SCENE_ACTIONS.events);
    this.runActions(events[String(eventName || '')], payload || {});
  }
};
function _runSceneIdleAction() {
  if (window.SakuraLive2DSceneActions) window.SakuraLive2DSceneActions.runIdleAction();
}
function _installSceneActionEventHandlers() {
  if (window.__sakuraSceneActionHandlersInstalled) return;
  window.__sakuraSceneActionHandlersInstalled = true;
  window.addEventListener('sakura:tts.started', function(event) {
    dispatchLive2DSceneEvent('tts.started', event.detail || {});
  });
  window.addEventListener('sakura:llm.request.started', function(event) {
    dispatchLive2DSceneEvent('llm.request.started', event.detail || {});
  });
  window.addEventListener('sakura:pet.clicked', function(event) {
    dispatchLive2DSceneEvent('pet.clicked', event.detail || {});
  });
  window.SakuraLive2DSceneActions.startIdleTimer();
}
window.dispatchLive2DSceneEvent = function(eventName, payload) {
  if (window.SakuraLive2DSceneActions) {
    window.SakuraLive2DSceneActions.dispatch(eventName, payload || {});
  }
};
window.triggerLive2DSceneAction = function(kind, name) {
  if (!window.SakuraLive2DSceneActions) return false;
  kind = String(kind || '').trim();
  name = name == null ? '' : String(name || '').trim();
  if (kind === 'idle') return window.SakuraLive2DSceneActions.runIdleAction();
  if (kind === 'layer') {
    var sep = name.indexOf(':');
    if (sep <= 0) return false;
    return window.SakuraLive2DSceneActions.applyLayer(name.slice(0, sep), name.slice(sep + 1));
  }
  if (kind === 'motion') return window.SakuraLive2DSceneActions.playMotionAction(name);
  if (kind === 'transient') return window.SakuraLive2DSceneActions.applyTransient(name);
  return false;
};
"""


def _w(msg: str) -> None:
    with _LOG.open("a", encoding="utf-8") as f:
        f.write(f"[{datetime.datetime.now()}] {msg}\n")


class _JavaScriptRunner(QObject):
    run_requested = Signal(str)
    run_with_callback_requested = Signal(str, object)

    def __init__(self, view: Any) -> None:
        super().__init__(view)
        self._view = view
        self.run_requested.connect(self._run, Qt.ConnectionType.QueuedConnection)
        self.run_with_callback_requested.connect(self._run_with_callback, Qt.ConnectionType.QueuedConnection)

    @Slot(str)
    def _run(self, script: str) -> None:
        try:
            if self._view is not None:
                self._view.page().runJavaScript(script)
        except Exception:  # noqa: BLE001 - JS 鎶曢€掑け璐ヤ笉鑳借鍚庡彴 worker 宕╀富杩涚▼
            _w("EXCEPTION in _JavaScriptRunner:\n" + traceback.format_exc())

    @Slot(str, object)
    def _run_with_callback(self, script: str, callback: Any) -> None:
        try:
            if self._view is not None:
                self._view.page().runJavaScript(script, callback)
        except Exception:  # noqa: BLE001 - JS 鎶曢€掑け璐ヤ笉鑳借鍚庡彴 worker 宕╀富杩涚▼
            _w("EXCEPTION in _JavaScriptRunner callback:\n" + traceback.format_exc())

    def submit(self, script: str) -> None:
        self.run_requested.emit(script)

    def submit_with_callback(self, script: str, callback: Any) -> None:
        self.run_with_callback_requested.emit(script, callback)


class Live2DRenderer(CharacterRenderer):
    renderer_name = "live2d"
    uses_owner_coordinates = False
    supports_drag_snapshot = True

    def __init__(self, ctx: RendererCreateContext) -> None:
        self._ctx = ctx
        self._view: Any | None = None
        self._js_runner: _JavaScriptRunner | None = None
        self._initialized = False
        self._mode = "half"
        self._last_geometry: tuple[int, int, int, int, int] | None = None
        self._last_stack_state: tuple[int | None, bool | None] | None = None

    @property
    def replaces_default_portrait(self) -> bool:
        return self._initialized and self._view is not None

    def is_available(self) -> bool:
        try:
            from PySide6.QtWebEngineWidgets import QWebEngineView  # noqa: F401
            return True
        except ImportError:
            return False

    def initialize(self, app_context: dict[str, Any] | None = None) -> None:
        try:
            cfg = self._ctx.renderer_config or {}
            self._mode = _normalize_mode(cfg.get("mode"))
            _w(f"initialize called: cfg={cfg}")
            _w(f"package_dir={self._ctx.package_dir}")

            # Prefer renderer_config.model_dir when present; it may be absolute or package-relative.
            model_dir_str = cfg.get("model_dir", "")
            if model_dir_str:
                model_dir = Path(model_dir_str)
                if not model_dir.is_absolute():
                    model_dir = (self._ctx.package_dir / model_dir).resolve()
            else:
                model_dir = self._ctx.package_dir

            model_name = cfg.get("model", "")
            model_path = (model_dir / model_name) if model_name else None
            _w(f"model_dir={model_dir} exists={model_dir.exists()}")
            _w(f"model_path={model_path} exists={model_path.exists() if model_path else 'N/A'}")

            if model_path is None or not model_path.exists():
                for search_root in (model_dir, self._ctx.package_dir):
                    found = list(search_root.rglob("*.model3.json"))
                    if found:
                        model_path = found[0]
                        _w(f"fallback found: {model_path}")
                        break

            if model_path is None or not model_path.exists():
                _w("ABORT: no model3.json found")
                raise FileNotFoundError("Live2D model3.json not found")

            vendor_dir = _PLUGIN_DIR / "vendor"
            html = _build_html(
                model_path,
                vendor_dir,
                mode=self._mode,
                model_scale=cfg.get("model_scale", 1.0),
                half_scale=cfg.get("half_scale", cfg.get("halfScale", 1.85)),
                full_scale=cfg.get("full_scale", cfg.get("fullScale", 0.98)),
                resolution_scale=cfg.get("resolution_scale", cfg.get("resolutionScale", 1.8)),
                max_resolution=cfg.get("max_resolution", cfg.get("maxResolution", 4.5)),
                half_offset_y=cfg.get("half_offset_y", cfg.get("halfOffsetY", 0.0)),
                full_offset_y=cfg.get("full_offset_y", cfg.get("fullOffsetY", 0.01)),
                safe_reset_params=cfg.get("safe_reset_params", cfg.get("safeResetParams")),
                hidden_parts=cfg.get("hidden_parts", cfg.get("hiddenParts")),
                hidden_drawables=cfg.get("hidden_drawables", cfg.get("hiddenDrawables")),
                disable_vendor_expressions=cfg.get(
                    "disable_vendor_expressions",
                    cfg.get("disableVendorExpressions", False),
                ),
                scene_actions=cfg.get("scene_actions", cfg.get("sceneActions")),
            )

            parent = self._ctx.owner_window
            from PySide6.QtWebEngineWidgets import QWebEngineView

            class DraggableLive2DView(QWebEngineView):
                def __init__(self, parent_widget: Any, owner_window: Any) -> None:
                    super().__init__(parent_widget)
                    self._owner_window = owner_window
                    self._event_filters_installed = False
                    self.setContextMenuPolicy(Qt.ContextMenuPolicy.DefaultContextMenu)

                def install_mouse_forwarders(self) -> None:
                    if self._event_filters_installed:
                        return
                    self.installEventFilter(self)
                    for child in self.findChildren(object):
                        install = getattr(child, "installEventFilter", None)
                        if callable(install):
                            install(self)
                    self._event_filters_installed = True

                def eventFilter(self, watched: Any, event: Any) -> bool:  # noqa: N802
                    event_type = event.type()
                    if event_type == QEvent.Type.ContextMenu:
                        return self._open_owner_menu(event)
                    if event_type == QEvent.Type.MouseButtonPress:
                        return self._forward_mouse_press(event, watched)
                    if event_type == QEvent.Type.MouseMove:
                        return self._forward_mouse_move(event)
                    if event_type == QEvent.Type.MouseButtonRelease:
                        return self._forward_mouse_release(event)
                    return super().eventFilter(watched, event)

                def contextMenuEvent(self, event: Any) -> None:  # noqa: N802
                    if self._open_owner_menu(event):
                        return
                    super().contextMenuEvent(event)

                def mousePressEvent(self, event: Any) -> None:  # noqa: N802
                    if self._forward_mouse_press(event, self):
                        return
                    super().mousePressEvent(event)

                def mouseMoveEvent(self, event: Any) -> None:  # noqa: N802
                    if self._forward_mouse_move(event):
                        return
                    super().mouseMoveEvent(event)

                def mouseReleaseEvent(self, event: Any) -> None:  # noqa: N802
                    if self._forward_mouse_release(event):
                        return
                    super().mouseReleaseEvent(event)

                def _open_owner_menu(self, event: Any) -> bool:
                    menu_handler = getattr(self._owner_window, "_show_context_menu", None)
                    if not callable(menu_handler):
                        return False
                    menu_handler(QPoint(0, 0))
                    event.accept()
                    return True

                def _forward_mouse_press(self, event: Any, source_widget: Any) -> bool:
                    if event.button() == Qt.MouseButton.RightButton:
                        return self._open_owner_menu(event)
                    handler = getattr(self._owner_window, "_handle_mouse_press", None)
                    return bool(callable(handler) and handler(event, source_widget))

                def _forward_mouse_move(self, event: Any) -> bool:
                    handler = getattr(self._owner_window, "_handle_mouse_move", None)
                    return bool(callable(handler) and handler(event))

                def _forward_mouse_release(self, event: Any) -> bool:
                    handler = getattr(self._owner_window, "_handle_mouse_release", None)
                    return bool(callable(handler) and handler(event))

            self._view = DraggableLive2DView(parent, parent)
            self._js_runner = _JavaScriptRunner(self._view)
            self._view.setAttribute(Qt.WidgetAttribute.WA_TranslucentBackground, True)
            self._view.page().setBackgroundColor(Qt.GlobalColor.transparent)
            self._view.setWindowFlags(
                Qt.WindowType.FramelessWindowHint
                | Qt.WindowType.Tool
                | Qt.WindowType.WindowStaysOnTopHint
            )

            tmp = _PLUGIN_DIR / "live2d_view.html"
            tmp.write_text(html, encoding="utf-8")
            self._view.load(QUrl.fromLocalFile(str(tmp)))
            self._view.resize(420, 570)
            self._view.show()
            self._view.install_mouse_forwarders()
            self._raise_owner_foreground_controls()
            status = _wait_for_live2d_status(self._view, timeout_ms=30000)
            _w("JS_STATUS: " + json.dumps(status, ensure_ascii=False))
            if not status.get("done"):
                raise RuntimeError(f"Live2D JS initialization failed: {status}")
            self._initialized = True
            _w("SUCCESS: view shown and model rendered")
        except Exception:
            _w("EXCEPTION:\n" + traceback.format_exc())
            self.close()
            raise

    def close(self) -> None:
        self._js_runner = None
        if self._view:
            self._view.close()
            self._view = None

    def capture_snapshot(self) -> Any | None:
        if not self._view:
            return None
        try:
            pixmap = self._view.grab()
            is_null = getattr(pixmap, "isNull", None)
            if callable(is_null) and is_null():
                return None
            return pixmap
        except Exception:  # noqa: BLE001 - snapshot fallback must not break rendering
            _w("EXCEPTION in capture_snapshot:\n" + traceback.format_exc())
            return None

    def _run_js(self, script: str) -> None:
        """Submit JavaScript to the QWebEngine thread."""
        if self._js_runner is not None:
            self._js_runner.submit(script)

    def _run_js_callback(self, script: str, callback: Any) -> None:
        """Submit JavaScript and route the runJavaScript result to Python."""
        if self._js_runner is not None:
            self._js_runner.submit_with_callback(script, callback)

    def show(self) -> None:
        if self._view:
            self._view.show()
            self._raise_owner_foreground_controls()

    def hide(self) -> None:
        if self._view:
            self._view.hide()

    def look_at(self, x: float, y: float) -> None:
        if self._view:
            self._run_js(f"lookAt({x}, {y})")

    def set_geometry(self, x: int, y: int, width: int, height: int, layout_height: int | None = None) -> None:
        if self._view:
            w = max(1, int(width))
            h = max(1, int(height))
            # Keep model scaling based on the full layout height even when the
            # WebEngine view is clipped above the foreground controls.
            lh = int(layout_height) if layout_height and int(layout_height) > 0 else h
            geometry = (int(x), int(y), w, h, lh)
            if getattr(self, "_last_geometry", None) == geometry:
                return
            self._last_geometry = geometry
            self._view.setGeometry(int(x), int(y), w, h)
            self._run_js(f"resizeLive2D({w}, {h}, {lh})")
            self._run_js("forceRenderLive2D()")

    def set_position(self, x: int, y: int) -> None:
        if self._view:
            self._view.move(int(x), int(y))

    def set_scale(self, scale: float) -> None:
        if not self._view:
            return
        next_scale = _normalize_model_scale(scale)
        self._run_js(f"setUserScale({json.dumps(next_scale)})")
        QTimer.singleShot(350, self._log_expression_debug)

    def set_mode(self, mode: str) -> None:
        if not self._view:
            return
        next_mode = _normalize_mode(mode)
        self._run_js(f"setMode({json.dumps(next_mode)})")
        QTimer.singleShot(350, self._log_expression_debug)

    def stack_below(self, owner_window: Any, *, topmost: bool | None = None) -> None:
        """Keep the independent Live2D overlay below the Sakura foreground controls."""
        if not self._view:
            return
        try:
            self._view.lower()
            if owner_window is not None:
                raise_owner = getattr(owner_window, "raise_", None)
                if callable(raise_owner):
                    raise_owner()
        except Exception:  # noqa: BLE001 - z-order failure must not break rendering
            _w("EXCEPTION in stack_below:\n" + traceback.format_exc())

    def _raise_owner_foreground_controls(self) -> None:
        owner = getattr(self._ctx, "owner_window", None)
        raise_controls = getattr(owner, "_raise_foreground_controls", None)
        if not callable(raise_controls):
            return
        try:
            raise_controls()
        except Exception:  # noqa: BLE001 - foreground controls are best-effort
            _w("EXCEPTION in _raise_owner_foreground_controls:\n" + traceback.format_exc())

    def set_expression(self, expression_name: str, weight: float = 1.0) -> None:
        if self._view:
            self._run_js(
                f"setExpression({json.dumps(expression_name)}, {weight})"
            )
            QTimer.singleShot(350, self._log_expression_debug)

    def play_motion(self, motion_name: str, loop: bool = False) -> None:
        if self._view:
            self._run_js(
                f"playMotion({json.dumps(motion_name)}, {str(loop).lower()})"
            )

    def trigger_scene_action(self, kind: str, name: str | None = None) -> None:
        if self._view:
            self._run_js(
                f"triggerLive2DSceneAction({json.dumps(kind)}, {json.dumps(name)})"
            )

    def handle_event(self, event_name: str, payload: dict[str, Any]) -> None:
        if not self._view:
            return
        payload = payload or {}
        if event_name in {"tts_started", "tts.started"}:
            self._run_js("setSpeaking(true)")
            self._dispatch_scene_event("tts.started", payload)
            QTimer.singleShot(350, self._log_expression_debug)
        elif event_name in {"tts_finished", "tts.finished"}:
            self._run_js("setSpeaking(false)")
            QTimer.singleShot(350, self._log_expression_debug)
        elif event_name in {"llm_request_started", "llm.request.started"}:
            self._run_js("setThinking(true)")
            self._dispatch_scene_event("llm.request.started", payload)
        elif event_name in {"llm_request_finished", "llm.request.finished", "llm.request.failed"}:
            self._run_js("setThinking(false)")
        elif event_name in {"pet_clicked", "pet.clicked"}:
            self._run_js("triggerInteraction(\"pet_clicked\")")
            self._dispatch_scene_event("pet.clicked", payload)

    def _dispatch_scene_event(self, event_name: str, payload: dict[str, Any]) -> None:
        self._run_js(
            f"dispatchLive2DSceneEvent({json.dumps(event_name)}, {json.dumps(payload, ensure_ascii=False)})"
        )

    def _log_expression_debug(self) -> None:
        if not self._view:
            return

        def got(value: Any) -> None:
            try:
                data = json.loads(value) if isinstance(value, str) and value else {"raw": value}
            except Exception as exc:  # noqa: BLE001
                data = {"parse_error": str(exc), "raw": value}
            _w("JS_EXPRESSION_DEBUG: " + json.dumps(data, ensure_ascii=False))
            debug_log("Live2DRenderer", "Live2D JS 琛ㄦ儏閬ユ祴", data)

        self._run_js_callback("getExpressionDebug()", got)


def _build_html(
    model_path: Path,
    vendor_dir: Path,
    *,
    mode: str = "half",
    model_scale: float = 1.0,
    half_scale: Any = 1.85,
    full_scale: Any = 0.98,
    resolution_scale: Any = 1.8,
    max_resolution: Any = 4.5,
    half_offset_y: Any = 0.0,
    full_offset_y: Any = 0.01,
